@misc{elharroussTaskbasedLossFunctions2025a,
  title = {Task-Based {{Loss Functions}} in {{Computer Vision}}: {{A Comprehensive Review}}},
  shorttitle = {Task-Based {{Loss Functions}} in {{Computer Vision}}},
  author = {Elharrouss, Omar and Mahmood, Yasir and Bechqito, Yassine and Serhani, Mohamed Adel and Badidi, Elarbi and Riffi, Jamal and Tairi, Hamid},
  year = 2025,
  month = sep,
  number = {arXiv:2504.04242},
