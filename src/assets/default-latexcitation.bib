  urldate = {2026-02-18},
  abstract = {We study stochastic zeroth order gradient and Hessian estimators for real-valued functions in \$\textbackslash mathbb\textbraceleft R\textbraceright\textasciicircum n\$. We show that, via taking finite difference along random orthogonal directions, the variance of the stochastic finite difference estimators can be significantly reduced. In particular, we design estimators for smooth functions such that, if one uses \$ {$\Theta\backslash$}left( k \textbackslash right) \$ random directions sampled from the Stiefel's manifold \$ \textbackslash text\textbraceleft St\textbraceright{} (n,k) \$ and finite-difference granularity \${$\delta\$$}, the variance of the gradient estimator is bounded by \$ \textbackslash mathcal\textbraceleft O\textbraceright{} \textbackslash left( \textbackslash left( \textbackslash frac\textbraceleft n\textbraceright\textbraceleft k\textbraceright{} - 1 \textbackslash right) + \textbackslash left( \textbackslash frac\textbraceleft n\textasciicircum 2\textbraceright\textbraceleft k\textbraceright{} - n \textbackslash right) {$\delta$}\textasciicircum 2 + \textbackslash frac\textbraceleft{} n\textasciicircum 2 {$\delta$}\textasciicircum 4 \textbraceright\textbraceleft{} k \textbraceright{} \textbackslash right) \$, and the variance of the Hessian estimator is bounded by \$\textbackslash mathcal\textbraceleft O\textbraceright{} \textbackslash left( \textbackslash left( \textbackslash frac\textbraceleft n\textasciicircum 2\textbraceright\textbraceleft k\textasciicircum 2\textbraceright{} - 1 \textbackslash right) + \textbackslash left( \textbackslash frac\textbraceleft n\textasciicircum 4\textbraceright\textbraceleft k\textasciicircum 2\textbraceright{} - n\textasciicircum 2 \textbackslash right) {$\delta$}\textasciicircum 2 + \textbackslash frac\textbraceleft n\textasciicircum 4 {$\delta$}\textasciicircum 4 \textbraceright\textbraceleft k\textasciicircum 2\textbraceright{} \textbackslash right) \$. When \$k = n\$, the variances become negligibly small. In addition, we provide improved bias bounds for the estimators. The bias of both gradient and Hessian estimators for smooth function \$f\$ is of order \$\textbackslash mathcal\textbraceleft O\textbraceright{} \textbackslash left( {$\delta$}\textasciicircum 2 {$\Gamma\backslash$}right)\$, where \${$\delta\$$} is the finite-difference granularity, and \$ {$\Gamma\$$} depends on high order derivatives of \$f\$. Our results are evidenced by empirical observations.},
  archiveprefix = {arXiv},
  keywords = {Computer Science - Machine Learning,Mathematics - Optimization and Control},
  file = {C\:\\Users\\hirok\\Zotero\\storage\\LRBQLJHA\\Feng と Wang - 2023 - Stochastic Zeroth Order Gradient and Hessian Estimators Variance Reduction and Refined Bias Bounds.pdf;C\:\\Users\\hirok\\Zotero\\storage\\MQ3HSQ28\\2205.html}
}

@misc{flaxmanOnlineConvexOptimization2004,
  title = {Online Convex Optimization in the Bandit Setting: Gradient Descent without a Gradient},
  shorttitle = {Online Convex Optimization in the Bandit Setting},
  author = {Flaxman, Abraham D. and Kalai, Adam Tauman and McMahan, H. Brendan},
  year = 2004,
  month = aug,
  journal = {arXiv.org},
  url = {https://arxiv.org/abs/cs/0408007v1},
  urldate = {2026-04-06},
  abstract = {We consider a the general online convex optimization framework introduced by Zinkevich. In this setting, there is a sequence of convex functions. Each period, we must choose a signle point (from some feasible set) and pay a cost equal to the value of the next function on our chosen point. Zinkevich shows that, if the each function is revealed after the choice is made, then one can achieve vanishingly small regret relative the best single decision chosen in hindsight. We extend this to the bandit setting where we do not find out the entire functions but rather just their value at our chosen point. We show how to get vanishingly small regret in this setting. Our approach uses a simple approximation of the gradient that is computed from evaluating a function at a single (random) point. We show that this estimate is sufficient to mimic Zinkevich's gradient descent online analysis, with access to the gradient (only being able to evaluate the function at a single point).},
  langid = {english},
  file = {C:\Users\hirok\Zotero\storage\J6XVYZ3F\Flaxman et al. - 2004 - Online convex optimization in the bandit setting gradient descent without a gradient.pdf}
}

