@article{tervenComprehensiveSurveyLoss2025,
  title = {A Comprehensive Survey of Loss Functions and Metrics in Deep Learning},
  author = {Terven, Juan and {Cordova-Esparza}, Diana-Margarita and {Romero-Gonz{\'a}lez}, Julio-Alejandro and {Ram{\'i}rez-Pedraza}, Alfonso and {Ch{\'a}vez-Urbiola}, E. A.},
  year = 2025,
