{
  "name": "latexpages",
  "displayName": "LaTeX Pages",
  "description": "Web versions of LaTeX tools and notes for academic writing",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "license": "Apache-2.0",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && python script/make_404_fallback.py",
    "lint": "eslint .",
    "preview": "vite preview",
    "generate": "python script/main.py",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
