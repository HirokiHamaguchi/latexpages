    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@monaco-editor/react": "^4.7.0",
    "@types/vscode": "^1.105.0",
    "framer-motion": "^12.23.24",
    "github-markdown-css": "^5.8.1",
    "kuromoji": "^0.1.2",
    "latexcitation": "git+https://github.com/HirokiHamaguchi/latexcitation.git#14378fea564e4015462cbb5117a05d9750474c64",
    "latexlint": "git+https://github.com/HirokiHamaguchi/latexlint.git#d517b53f6381cf5583301d9f94588d0bd6428810",
    "monaco-editor": "^0.53.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-icons": "^5.5.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.17.0",
